# PDFs (large binaries — keep locally, don't track in git)
papers/*.pdf

# SQLite temp files
*.db-journal
*.db-wal
*.db-shm
.scq_tmp.db

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc

# Node
node_modules/

# Auto-memory (Cowork session state)
.auto-memory/

# Overleaf sync (Git cloned repo — don't track)
.overleaf/

# Editor
*.swp
*.swo
*~

# Claude local settings
.claude/settings.local.json

# Personal launcher with hardcoded Windows paths
tools/run_digest.bat

# Scratch files from ad-hoc GitHub API updates
tools/update_digest.json
tools/update_workflow.json

# Inbox runtime state
inbox/processed/

# Local planning docs (not tracked)
plans/

# User config overrides — only commit the *.example starter templates,
# never the real files (which contain emails, paths, and other personal data)
data/user_config/*.json
data/user_config/*.toml

# Legacy: superseded by data/user_config/digest.json. Keep the file ignored
# so leftover working copies don't get re-tracked. Migration is automatic
# in tools/arxiv_digest.py — but the canonical location is now user_config.
email_recipients.json
