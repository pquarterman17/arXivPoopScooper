{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scq://schema/search-sources",
  "title": "Search sources, presets, and arXiv categories",
  "description": "Replaces the legacy scraper_config.js. Both the browser scraper and the Python digest read from this file (via the same merged config).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "arxivCategories": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "description": "arXiv category IDs scanned by the daily digest and the scraper's category filter."
    },
    "sources": {
      "type": "array",
      "x-mergeKey": "id",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Stable identifier; user overrides target sources by id."
          },
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["arxiv", "arxiv-jr", "crossref"]
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          },
          "enabled": { "type": "boolean" },
          "journalRef": {
            "type": "string",
            "description": "Used by type='arxiv-jr' to filter on the journal_ref field."
          },
          "journalName": { "type": "string" },
          "issn": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{3}[0-9X]$",
            "description": "Used by type='crossref' to filter on the journal ISSN."
          }
        }
      }
    },
    "presets": {
      "type": "array",
      "x-mergeKey": "id",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "query"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "label": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 },
          "sources": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true,
            "description": "Optional: restrict this preset to specific source ids."
          }
        }
      }
    },
    "autoFetch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "cooldownHours": { "type": "integer", "minimum": 0, "maximum": 168 },
        "maxResultsPerQuery": { "type": "integer", "minimum": 1, "maximum": 100 },
        "delayBetweenQueriesMs": { "type": "integer", "minimum": 0, "maximum": 60000 }
      }
    }
  }
}
