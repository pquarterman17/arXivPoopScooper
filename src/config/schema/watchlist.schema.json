{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scq://schema/watchlist",
  "title": "Watchlist",
  "description": "Authors, groups, and keywords whose matches get highlighted in scraper results and boosted in digest ranking.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "groups": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
