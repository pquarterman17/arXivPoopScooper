{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "noEmit": true,
    "allowJs": true,
    "strict": false,
    "noImplicitThis": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/core/**/*.js",
    "src/dev/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".claude/worktrees",
    "src/tests"
  ]
}
